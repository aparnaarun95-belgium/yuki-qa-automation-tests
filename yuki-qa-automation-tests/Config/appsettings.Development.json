{
  "PlaywrightSettings": {
    "BaseUrl": "https://localhost:3000",
    "BrowserType": "chromium",
    "Headless": false,
    "SlowMo": 500,
    "Timeout": 30000,
    "NavigationTimeout": 30000,
    "ScreenshotOnFailure": true,
    "VideoOnFailure": true,
    "TraceOnFailure": true
  },
  "RetryPolicy": {
    "MaxRetries": 2,
    "DelayMilliseconds": 500
  },
  "Waits": {
    "DefaultWaitTimeMs": 3000,
    "ElementWaitTimeMs": 5000,
    "NavigationWaitTimeMs": 15000
  }
}
